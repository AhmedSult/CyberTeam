# انسخ هذا الملف إلى اسم .env في نفس المجلد (backend/.env) — لا ترفع .env إلى Git
# الأمر: cp .env.example .env
#
OPENAI_API_KEY=
# جرّب gpt-4o لرؤية أعمق (تكلفة أعلى) أو gpt-4o-mini للتوفير
OPENAI_MODEL=gpt-4o-mini
# ثبات الإجابات (0.25–0.45 مثالي للامتثال)؛ رفع بسيط يزيد تنويع الصياغة
# OPENAI_TEMPERATURE=0.38
# هيكلة الإجابات: ملخص → تحليل → توصيات (تعطيل: AI_STRUCTURED_INSIGHTS=false)
# AI_STRUCTURED_INSIGHTS=true
# OPENAI_MAX_TOKENS_CHAT=2800
# OPENAI_MAX_TOKENS_GAP=1200
# OPENAI_MAX_TOKENS_EXPLAIN=1600

# اختياري: نص عربي يُلحق برسالة «النظام» للمساعد ولتحليل الفجوات — لتثبيت معاييركم (مثلاً ملخص ضوابط أساسية، ECC، سياسات داخلية معتمدة).
# هذا توجيه للنموذج وليس تدريباً (fine-tuning). للأسطر المتعددة استخدم \n داخل السطر أو سطر واحد طويل.
# AI_SA_CYBER_CONTEXT_EXTRA=

# فهرسة PDF الرسمي ECC-2-2024 من cdn.nca.gov.sa للمساعد (RAG). التعطيل: ECC_KB_ENABLED=false
# إعادة تنزيل وبناء الفهرس يدوياً: ECC_FORCE_REBUILD=true (مرة واحدة ثم أعد false أو احذف السطر)
# ECC_PDF_URL=https://cdn.nca.gov.sa/api/files/public/upload/29a9e86a-595f-4af9-8db5-88715a458a14_ECC-2-2024---NCA.pdf
# ECC_RETRIEVAL_TOP_N=12
# ECC_RETRIEVAL_MAX_CHARS=16000

# أمان JWT: إن غيّرت هذا المفتاح بعد تشغيل السيرفر، يصبح كل رمز دخول قديم «غير صالح» — سجّل دخولاً من جديد
# استخدم قيمة عشوائية طويلة (إنجليزي/hex) وليس جملة عربية قصيرة
SECRET_KEY=
